NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Cloud Run base URL (for MVP). Example:
# NEXT_PUBLIC_API_BASE_URL=https://your-cloud-run-url.a.run.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: enables App Check tokens from the browser.
# NEXT_PUBLIC_APP_CHECK_SITE_KEY=your_recaptcha_site_key
NEXT_PUBLIC_APP_CHECK_SITE_KEY=

